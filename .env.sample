# ── Literature source ──────────────────────────────────────────────────────────
# OpenAlex API key (https://openalex.org/settings/api)
OPEN_ALEX_KEY=...

# ── LLM provider (any OpenAI-compatible endpoint) ─────────────────────────────
URL_BASE=...
LLM_API_KEY=...
LLM_MODEL=...
# Examples: deepseek-chat, gpt-4o-mini, glm-4-flash
# Prefer a mini/small model to keep cost low (~$0.014 per run at current settings)

# ── Hugging Face (https://huggingface.co/settings/tokens) ─────────────────────
# Required for deployment to HF Spaces via GitHub Actions
HF_TOKEN=...

# ── Observability — Langfuse (optional) ───────────────────────────────────────
# Set these to enable full LangGraph tracing and LLM-as-a-judge evaluations.
# Get keys at https://cloud.langfuse.com  (free tier available)
# Leave blank or unset to run without tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Topic model (optional — defaults shown) ───────────────────────────────────
# Number of BERTopic clusters (leave unset for automatic)
TOPIC_MODEL_K=12
# Max characters per abstract fed to embeddings (controls token budget)
TOPIC_MODEL_MAX_DOC_CHARS=300
# SBERT model — paraphrase-MiniLM-L3-v2 is fast and lightweight
TOPIC_MODEL_EMBEDDING_MODEL=sentence-transformers/paraphrase-MiniLM-L3-v2
